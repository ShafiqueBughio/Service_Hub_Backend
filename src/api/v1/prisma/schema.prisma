generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum user_type {
  USER
  CONTRACTOR
  ADMIN
}

enum Mute_duration {
  EIGHT_HOURS
  ONE_WEEK
  ALWAYS
}

enum screen_name {
  USER_REQUESTS
  USER_INVITES
  JOB
  TRANSACTION_DEBIT
  TRANSACTION_CREDIT
}

// user start
model users {
  id          String  @id @default(uuid())
  referred_by String?

  email                String?  @db.VarChar(255)
  phone                String?  @db.VarChar(255)
  mute_notifications   Boolean? @default(false)
  social_account_token String?  @db.VarChar(255)
  is_email_verified    Boolean  @default(false)
  is_phone_verified    Boolean  @default(false)
  is_completed         Boolean  @default(false)
  is_subscribed        Boolean  @default(false)
  is_blocked           Boolean? @default(false)
  is_approved          Boolean? @default(true)

  user_type user_type?

  user_secrets           user_secrets?
  user_details           user_details?
  contractor_profile     contractor_profile?
  user_sessions          user_sessions[]
  help_and_feedback      help_and_feedback[] @relation("senders")
  notification_receivers notifications[]     @relation("notification_receivers")
  blocked_user           block_user[]        @relation("blocked_user")
  blocked_by             block_user[]        @relation("blocked_by")
  jobs                   Job[]
  jobs_invited           Job[]               @relation("JobInvitedContractor") // Request Service – in contractor k pending me
  bids                   Bid[] // bids placed as contractor
  reviews_given          Review[]            @relation("reviews_given")
  reviews_received       Review[]            @relation("reviews_received")
  chat_messages_sent     ChatMessage[]       @relation("chat_sent")
  chat_messages_received ChatMessage[]       @relation("chat_received")

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model user_details {
  id      String @id @default(uuid())
  user_id String @unique

  first_name      String?
  last_name       String?
  date_of_birth   DateTime?
  location        String?   @db.VarChar(255)
  city            String?
  state           String?
  contact_email   String?
  contact_phone   String?
  profile_picture String?   @db.Text
  latitude        String?
  longitude       String?
  gender          String?   @db.VarChar(50)
  address         String?   @db.VarChar(500)

  users users? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model user_secrets {
  id      String @id @default(uuid())
  user_id String @unique

  otp            String?  @db.VarChar(255)
  password       String?  @db.VarChar(255)
  otp_expiration DateTime @db.DateTime()

  users users? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model user_sessions {
  id      String  @id @default(uuid())
  user_id String?

  fcm_token         String? @db.LongText
  refresh_token     String  @unique @db.VarChar(255)
  mute_notification Boolean @default(true)

  users users? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

// chat and notifications start

// public end

// contractor start
model contractor_profile {
  id      String @id @default(uuid())
  user_id String @unique

  about String? @db.LongText

  contractor_experiences   contractor_experience[]
  contractor_documents     contractor_documents[]
  contractor_portfolios    contractor_portfolio[]
  contractor_services      contractor_services[]
  contractor_service_areas contractor_service_areas[]

  users users? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model contractor_experience {
  id                    String @id @default(uuid())
  contractor_profile_id String

  company     String? @db.VarChar(255)
  job_type    String? @db.VarChar(100)
  designation String? @db.VarChar(255)
  start_year  String? @db.VarChar(10)
  end_year    String? @db.VarChar(10)

  contractor_profile contractor_profile? @relation(fields: [contractor_profile_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model contractor_documents {
  id                    String @id @default(uuid())
  contractor_profile_id String

  document_type String  @db.VarChar(100) // BUSINESS_LICENSE, CERTIFICATION
  document_url  String? @db.VarChar(500)

  contractor_profile contractor_profile? @relation(fields: [contractor_profile_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model contractor_portfolio {
  id                    String @id @default(uuid())
  contractor_profile_id String

  image_url String? @db.VarChar(500)

  contractor_profile contractor_profile? @relation(fields: [contractor_profile_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model contractor_services {
  id                    String @id @default(uuid())
  contractor_profile_id String

  service_name String? @db.VarChar(255)

  contractor_profile contractor_profile? @relation(fields: [contractor_profile_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model contractor_service_areas {
  id                    String @id @default(uuid())
  contractor_profile_id String

  location  String? @db.VarChar(255)
  latitude  String?
  longitude String?

  contractor_profile contractor_profile? @relation(fields: [contractor_profile_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

// contractor end 
model notifications {
  id String @id @default(uuid())

  title        String?      @db.VarChar(255)
  message      String?      @db.LongText
  recipient_id String?
  metadata     String?      @db.VarChar(255)
  is_read      Boolean      @default(false)
  is_admin     Boolean      @default(false)
  screen_name  screen_name?

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt

  notification_receivers users? @relation(fields: [recipient_id], name: "notification_receivers", references: [id], onDelete: Cascade)
}

model block_user {
  id              String  @id @default(uuid())
  blocked_user_id String?
  blocked_by_id   String?

  blocked_user users? @relation(fields: [blocked_user_id], name: "blocked_user", references: [id], onDelete: Cascade)
  blocked_by   users? @relation(fields: [blocked_by_id], name: "blocked_by", references: [id], onDelete: Cascade)

  created_at DateTime  @default(now()) @db.Timestamp(0)
  updated_at DateTime? @updatedAt
}

// chat and notification end

// public start
model terms_and_conditions {
  id String @id @default(uuid())

  description String? @db.LongText

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model privacy_policy {
  id String @id @default(uuid())

  description String? @db.LongText

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model about_app {
  id String @id @default(uuid())

  description String? @db.LongText

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model help_and_feedback {
  id String @id @default(uuid())

  subject   String? @db.VarChar(1000)
  message   String? @db.LongText
  sender_id String

  help_and_feedback_images help_and_feedback_images[]
  senders                  users                      @relation(fields: [sender_id], name: "senders", references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

model help_and_feedback_images {
  id                   String @id @default(uuid())
  help_and_feedback_id String

  review_image String? @db.VarChar(255)

  help_and_feedback help_and_feedback? @relation(fields: [help_and_feedback_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt
}

enum JobType {
  REGULAR
  LIVE
}

enum JobStatus {
  OPEN
  CLOSED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Job {
  id      String @id @default(uuid())
  user_id String

  job_type    JobType
  title       String
  description String

  min_budget Float?
  max_budget Float?

  expire_days Int?
  timeline    String?
  location    String?

  provider_preferences Json? // array (skills, gender, experience etc)
  attachments          Json? // images / videos / pdf (array)

  status JobStatus @default(OPEN)

  accepted_bid_id       String?   @unique // set when owner accepts one bid
  is_completed          Boolean   @default(false) // user mark as completed → true
  is_cancelled          Boolean   @default(false) // job cancel → true
  invited_contractor_id String? // user "Request Service" from completed job – ye job is contractor k pending me jata he

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  user               users   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  invited_contractor users?  @relation("JobInvitedContractor", fields: [invited_contractor_id], references: [id], onDelete: SetNull)
  bids               Bid[]
  accepted_bid       Bid?    @relation("JobAcceptedBid", fields: [accepted_bid_id], references: [id])
  review             Review?
  chat               Chat?   // ek job = ek chat room (user + accepted contractor); sirf active job pe chat

  @@index([user_id])
  @@index([invited_contractor_id])
  @@map("jobs")
}

// Chat = ek job ke liye ek room (job owner + accepted bid contractor). Sirf ACTIVE job pe message bhej sakte; completed pe read-only.
model Chat {
  id        String   @id @default(uuid())
  job_id    String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  job    Job           @relation(fields: [job_id], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chats")
}

model ChatMessage {
  id         String   @id @default(uuid())
  chat_id    String
  sender_id  String
  recipient_id String? // other participant (job owner ya contractor)
  message    String?  @db.LongText
  attachment String?  @db.Text
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(0)

  chat     Chat   @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  sender   users  @relation("chat_sent", fields: [sender_id], references: [id], onDelete: Cascade)
  recipient users? @relation("chat_received", fields: [recipient_id], references: [id], onDelete: SetNull)

  @@index([chat_id])
  @@index([sender_id])
  @@map("chat_messages")
}

model Bid {
  id            String @id @default(uuid())
  job_id        String
  contractor_id String // user who placed the bid

  quote_price        Float // quotation price
  timeline_estimate  String? // e.g. "2 weeks"
  notes              String? @db.LongText
  proposal_documents Json? // array of file URLs (from presigned uploads)

  status BidStatus @default(PENDING)
  reject_reason String? @db.Text // user reject kare to reason (Past → Rejected screen pe dikhega)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  job          Job   @relation(fields: [job_id], references: [id], onDelete: Cascade)
  contractor   users @relation(fields: [contractor_id], references: [id], onDelete: Cascade)
  job_accepted Job?  @relation("JobAcceptedBid")

  @@index([job_id])
  @@index([contractor_id])
  @@map("bids")
}

// User (job owner) gives review for completed job – rating + review text (Give Review screen)
model Review {
  id            String @id @default(uuid())
  job_id        String @unique
  reviewer_id   String // job owner (user) who gives review
  contractor_id String // contractor who did the job (accepted bid)

  rating      Int // 1-5 stars
  review_text String? @db.Text

  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt

  job        Job   @relation(fields: [job_id], references: [id], onDelete: Cascade)
  reviewer   users @relation("reviews_given", fields: [reviewer_id], references: [id], onDelete: Cascade)
  contractor users @relation("reviews_received", fields: [contractor_id], references: [id], onDelete: Cascade)

  @@index([job_id])
  @@index([contractor_id])
  @@index([reviewer_id])
  @@map("reviews")
}
